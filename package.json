{
  "name": "printr",
  "version": "1.0.0",
  "description": "Local web printing interface hosted on Mac Mini",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node server.ts",
    "dev:server": "nodemon --watch server.ts --exec ts-node server.ts",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --prefix client && tsc",
    "prod": "node server.js"
  },
  "dependencies": {
    "express": "^4.22.1",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
